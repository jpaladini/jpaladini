# --- Azure DevOps Enterprise Console ---

# Secret used to sign/encrypt the session cookie that stores the user's
# Azure DevOps credentials server-side. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-32-byte-random-string

# Optional: pin the console to a single Azure DevOps organization.
# If set, the login screen will pre-fill (and can lock) the org field.
# Example: contoso  ->  https://dev.azure.com/contoso
# AZDO_DEFAULT_ORG=

# Optional: default Azure DevOps REST API version.
AZDO_API_VERSION=7.1
