# Supabase Configuration (used for login/auth pages)
# Get these values from your Supabase project settings at https://app.supabase.com
PUBLIC_SUPABASE_URL=your-project-url.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis (used for baby shower wall of encouragement)
# Get these from your Upstash dashboard at https://console.upstash.com
PUBLIC_UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
PUBLIC_UPSTASH_REDIS_REST_TOKEN=your-rest-token
