---
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  /** Which nav item to highlight as active. */
  active?: 'home' | 'projects' | 'blog' | null;
  /** Footer style: 'home' shows the email + cursor; 'default' shows nav links. */
  footer?: 'home' | 'default';
}

const {
  title = 'Jason Paladini',
  description = 'Jason Paladini — Data Engineer',
  active = null,
  footer = 'default',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/projects', label: 'Projects', key: 'projects' },
  { href: '/blog', label: 'Blog', key: 'blog' },
  { href: '/jason-paladini-resume.pdf', label: 'Resume', key: 'resume', external: true },
];
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0d10" />
    <link rel="icon" type="image/png" href="/jp_black.png" />
    <link rel="canonical" href={`https://jpaladini.com${Astro.url.pathname}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jason Paladini",
      "jobTitle": "Data Engineer",
      "url": "https://jpaladini.com",
      "sameAs": [
        "https://github.com/jpaladini",
        "https://linkedin.com/in/jason-paladini"
      ]
    })} />

    <Analytics />
  </head>

  <body class="bg-bg text-text font-sans antialiased min-h-screen overflow-x-hidden">
    <!-- Top navigation -->
    <nav aria-label="Primary" class="sticky top-0 z-50 backdrop-blur-md bg-bg/[0.78] border-b border-white/[0.07]">
      <div class="max-w-content mx-auto px-8 py-3.5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="Jason Paladini — Home">
          <span class="w-[26px] h-[26px] rounded-md bg-accent text-accent-ink flex items-center justify-center font-bold text-[13px] leading-none">JP</span>
          <span class="font-semibold text-sm tracking-[0.02em]">Jason Paladini</span>
        </a>
        <div class="flex items-center gap-1 text-[13px] font-medium">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'inline-flex items-center min-h-[44px] px-3 rounded-[7px] transition-colors',
                active === link.key
                  ? 'text-text bg-white/[0.06]'
                  : 'text-text-3 hover:text-text hover:bg-white/[0.06]',
              ]}
              aria-current={active === link.key ? 'page' : undefined}
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener' : undefined}
            >
              {link.label}
            </a>
          ))}
          <a
            href="mailto:jason@jpaladini.com"
            class="inline-flex items-center min-h-[44px] px-3.5 ml-2 rounded-[7px] bg-accent text-accent-ink font-semibold transition-colors hover:bg-accent-bright"
          >
            Contact
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    {footer === 'home' ? (
      <footer class="border-t border-white/[0.07]">
        <div class="max-w-content mx-auto px-8 py-[26px] flex justify-between items-center flex-wrap gap-3">
          <span class="font-mono text-xs text-text-faint">
            jason@jpaladini.com<span class="blink-cursor"></span>
          </span>
          <span class="font-mono text-xs text-text-faint">© 2026 Jason Paladini · built in NJ</span>
        </div>
      </footer>
    ) : (
      <footer class="border-t border-white/[0.07] mt-12">
        <div class="max-w-content mx-auto px-8 py-[26px] flex justify-between items-center flex-wrap gap-3">
          <div class="flex gap-4 font-mono text-xs font-medium">
            <a href="/" class="text-text-3 no-underline hover:text-accent transition-colors">Home</a>
            <a href="/blog" class="text-text-3 no-underline hover:text-accent transition-colors">Blog</a>
            <a href="/projects" class="text-text-3 no-underline hover:text-accent transition-colors">Projects</a>
            <a href="https://github.com/jpaladini" target="_blank" rel="noopener" class="text-text-3 no-underline hover:text-accent transition-colors">GitHub</a>
          </div>
          <span class="font-mono text-xs text-text-faint">© 2026 Jason Paladini</span>
        </div>
      </footer>
    )}

    <style is:global>
      a { color: inherit; }

      /* Engineering grid texture for hero / page headers */
      .grid-texture {
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 34px 34px;
      }

      /* Mint radial glow (hero / contact / featured) */
      .mint-glow::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(700px 360px at 78% -8%, rgba(110, 231, 199, 0.14), transparent 70%);
        pointer-events: none;
      }

      /* Striped placeholder for project / cover images */
      .stripe-placeholder {
        background: repeating-linear-gradient(
          135deg,
          rgba(110, 231, 199, 0.07),
          rgba(110, 231, 199, 0.07) 8px,
          transparent 8px,
          transparent 16px
        );
        border: 1px solid rgba(110, 231, 199, 0.18);
      }

      /* Blinking mint cursor */
      .blink-cursor {
        display: inline-block;
        width: 7px;
        height: 13px;
        background: #6ee7c7;
        margin-left: 6px;
        vertical-align: -2px;
        animation: dvblink 1.1s step-end infinite;
      }
      @keyframes dvblink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
      }
    </style>
  </body>
</html>
