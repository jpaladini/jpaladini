---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 · Page Not Found" description="This page doesn't exist.">
  <div class="max-w-2xl mx-auto px-6 py-24 sm:py-32 text-center">
    <p class="text-6xl font-bold text-gray-200 dark:text-gray-700 mb-6">404</p>
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Page not found</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      This page doesn't exist or may have moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
    >
      ← Back home
    </a>
  </div>
</MainLayout>
