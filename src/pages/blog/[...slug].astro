---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout title={`${post.data.title} - Jason Paladini`} description={post.data.description}>
  <div class="max-w-2xl mx-auto px-6 py-12 sm:py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-6 text-sm">
      <a href="/" class="text-blue-600 dark:text-blue-400 underline font-medium hover:text-blue-700 dark:hover:text-blue-300">Home</a>
      <span class="mx-2 text-gray-400">/</span>
      <a href="/blog" class="text-blue-600 dark:text-blue-400 underline font-medium hover:text-blue-700 dark:hover:text-blue-300">Blog</a>
      <span class="mx-2 text-gray-400">/</span>
      <span class="text-gray-600 dark:text-gray-400">{post.data.title}</span>
    </nav>

    <article>
      <header class="mb-10 pb-8 border-b border-gray-200 dark:border-gray-700">
        <h1 class="text-3xl sm:text-4xl font-bold mb-4 leading-tight">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sm text-gray-500 dark:text-gray-500">
          <span>{post.data.author}</span>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
        </div>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-4">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-0.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="post-body">
        <Content />
      </div>
    </article>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <a href="/blog" class="inline-flex items-center text-blue-600 dark:text-blue-400 text-sm font-medium hover:text-blue-700 dark:hover:text-blue-300">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
        </svg>
        Back to all posts
      </a>
    </div>
  </div>
</MainLayout>

<!-- Render mermaid code fences (converted to <pre class="mermaid"> at build time) as diagrams. -->
<script>
  import mermaid from 'mermaid';

  const isDark = document.documentElement.classList.contains('dark');
  mermaid.initialize({
    startOnLoad: false,
    theme: isDark ? 'dark' : 'default',
    securityLevel: 'strict',
    fontFamily: 'ui-sans-serif, system-ui, sans-serif',
  });

  const nodes = document.querySelectorAll('.mermaid');
  if (nodes.length) {
    mermaid.run({ nodes: Array.from(nodes) as HTMLElement[] });
  }
</script>

<style is:global>
  /* Typographic styling for rendered markdown. Scoped to .post-body so it
     doesn't leak into the rest of the site. */
  .post-body {
    color: rgb(55 65 81); /* gray-700 */
    line-height: 1.75;
  }
  :global(.dark) .post-body {
    color: rgb(209 213 219); /* gray-300 */
  }

  .post-body > p:first-of-type {
    font-size: 1.125rem;
    color: rgb(75 85 99); /* gray-600 */
  }
  :global(.dark) .post-body > p:first-of-type {
    color: rgb(156 163 175); /* gray-400 */
  }

  .post-body p {
    margin: 1.25rem 0;
  }

  .post-body h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    padding-top: 0.5rem;
    color: rgb(17 24 39); /* gray-900 */
  }
  :global(.dark) .post-body h2 {
    color: rgb(243 244 246); /* gray-100 */
  }

  .post-body h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: rgb(17 24 39);
  }
  :global(.dark) .post-body h3 {
    color: rgb(243 244 246);
  }

  .post-body ul,
  .post-body ol {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }
  .post-body ul { list-style: disc; }
  .post-body ol { list-style: decimal; }
  .post-body li { margin: 0.5rem 0; }

  .post-body a {
    color: rgb(37 99 235); /* blue-600 */
    text-decoration: underline;
  }
  :global(.dark) .post-body a {
    color: rgb(96 165 250); /* blue-400 */
  }

  .post-body strong {
    font-weight: 600;
    color: rgb(17 24 39);
  }
  :global(.dark) .post-body strong {
    color: rgb(243 244 246);
  }

  /* Inline code */
  .post-body :not(pre) > code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
    background: rgb(243 244 246);
    color: rgb(190 24 93); /* pink-700-ish */
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }
  :global(.dark) .post-body :not(pre) > code {
    background: rgb(30 41 59); /* slate-800 */
    color: rgb(244 114 182); /* pink-400 */
  }

  /* Code blocks */
  .post-body pre {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
    background: rgb(248 250 252); /* slate-50 */
    border: 1px solid rgb(226 232 240); /* slate-200 */
  }
  :global(.dark) .post-body pre {
    background: rgb(15 23 42); /* slate-900 */
    border-color: rgb(51 65 85); /* slate-700 */
  }
  .post-body pre code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  /* Mermaid diagrams render to SVG; center them and drop the code-block chrome. */
  .post-body pre.mermaid {
    background: transparent;
    border: none;
    padding: 0;
    text-align: center;
  }

  /* Tables */
  .post-body table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .post-body th,
  .post-body td {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border: 1px solid rgb(226 232 240);
    vertical-align: top;
  }
  :global(.dark) .post-body th,
  :global(.dark) .post-body td {
    border-color: rgb(51 65 85);
  }
  .post-body th {
    background: rgb(248 250 252);
    font-weight: 600;
    color: rgb(17 24 39);
  }
  :global(.dark) .post-body th {
    background: rgb(30 41 59);
    color: rgb(243 244 246);
  }

  /* Image placeholders (swap these out for real screenshots) */
  .post-body figure.img-placeholder {
    margin: 1.75rem 0;
    padding: 2rem 1.25rem;
    border: 2px dashed rgb(203 213 225); /* slate-300 */
    border-radius: 0.5rem;
    background: rgb(248 250 252);
    text-align: center;
  }
  :global(.dark) .post-body figure.img-placeholder {
    border-color: rgb(51 65 85);
    background: rgb(30 41 59);
  }
  .post-body figure.img-placeholder span {
    font-size: 0.8rem;
    color: rgb(100 116 139); /* slate-500 */
  }

  /* Horizontal rule */
  .post-body hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px solid rgb(226 232 240);
  }
  :global(.dark) .post-body hr {
    border-top-color: rgb(51 65 85);
  }

  .post-body em {
    font-style: italic;
  }
</style>
