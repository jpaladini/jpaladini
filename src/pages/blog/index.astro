---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout
  title="Blog - Jason Paladini"
  description="Writing on data engineering, Databricks, and shipping software by Jason Paladini"
>
  <div class="max-w-2xl mx-auto px-6 py-12 sm:py-16">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-6 text-sm">
      <a href="/" class="text-blue-600 dark:text-blue-400 underline font-medium hover:text-blue-700 dark:hover:text-blue-300">Home</a>
      <span class="mx-2 text-gray-400">/</span>
      <span class="text-gray-600 dark:text-gray-400">Blog</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold mb-2">Blog</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">Field notes on data engineering, Databricks, and shipping software.</p>
    </header>

    {posts.length === 0 ? (
      <p class="text-gray-600 dark:text-gray-400">No posts yet — check back soon.</p>
    ) : (
      <ul class="space-y-10">
        {posts.map((post) => (
          <li>
            <article>
              <a href={`/blog/${post.id}/`} class="group block">
                <time datetime={post.data.date.toISOString()} class="text-sm text-gray-500 dark:text-gray-500">
                  {dateFmt.format(post.data.date)}
                </time>
                <h2 class="text-xl font-bold mt-1 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
                  {post.data.description}
                </p>
              </a>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {post.data.tags.map((tag) => (
                    <span class="px-2 py-0.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))}
      </ul>
    )}
  </div>
</MainLayout>
