---
import MainLayout from '../layouts/MainLayout.astro';

const projects = [
  {
    num: '01',
    title: 'Power BI vs Snowflake Comparison',
    description: 'Performance and feature comparison between Power BI semantic models and Snowflake. Modeling strategies, query optimization and cost analysis across platforms.',
    features: ['Side-by-side benchmarking', 'Query optimization insights', 'TCO comparison'],
    tags: ['Streamlit', 'Python', 'Power BI', 'Snowflake'],
    url: 'https://jphzn-pbi-snwflk-compare-20260125.streamlit.app/',
  },
  {
    num: '02',
    title: 'Power BI Model Explorer',
    description: 'Interactive exploration of Power BI semantic models and dbt relationships. Visualizes lineage, dependencies and metadata to help teams understand complex data models.',
    features: ['dbt model lineage', 'Relationship mapping', 'Metadata analysis'],
    tags: ['Streamlit', 'dbt', 'Power BI'],
    url: 'https://jp-pbi-model-explorer.streamlit.app/',
  },
  {
    num: '03',
    title: 'Data Profiling Tool',
    description: 'Automated data quality assessment and profiling. Analyzes datasets for statistical patterns, null values, type validation and quality issues — quick understanding of new data sources.',
    features: ['Statistical distributions', 'Quality metrics & alerts', 'Null & type validation'],
    tags: ['Streamlit', 'Python', 'Data Quality'],
    url: 'https://jphzn-profiling.streamlit.app/',
  },
  {
    num: '04',
    title: 'Claims Timeliness Dashboard',
    description: 'Healthcare claims processing KPIs and trend analysis. Tracks processing times, bottlenecks and operational metrics — domain expertise in healthcare analytics and BI.',
    features: ['Time-series analysis', 'Bottleneck identification', 'Operational KPIs'],
    tags: ['Streamlit', 'Business Intelligence', 'Healthcare'],
    url: 'https://jp-claims-timeliness.streamlit.app/',
  },
  {
    num: '05',
    title: 'SRA Timeline',
    description: 'Strategic roadmap and milestone tracking visualization. An interactive timeline for project planning, dependency management and progress tracking — advanced Streamlit component work.',
    features: ['Interactive timeline', 'Milestone & dependency tracking', 'Planning interface'],
    tags: ['Streamlit', 'Python', 'Data Visualization'],
    url: 'https://jphzn-sra-timeline.streamlit.app/',
  },
  {
    num: '06',
    title: 'Chess Game',
    description: 'Interactive chess application with move validation and game-state management. A change of pace — algorithmic thinking, state patterns and interactive UI in Streamlit.',
    features: ['Complete chess logic', 'Game-state management', 'Clean UI/UX'],
    tags: ['Streamlit', 'Python'],
    url: 'https://jp-chess.streamlit.app/',
  },
];

const techBars = [
  { label: 'Streamlit', count: '6 projects', width: '100%', opacity: 1 },
  { label: 'Python', count: '5 projects', width: '83%', opacity: 1 },
  { label: 'Data Engineering', count: '3 projects', width: '50%', opacity: 0.6 },
  { label: 'Power BI', count: '2 projects', width: '33%', opacity: 0.6 },
  { label: 'Snowflake · dbt · BI', count: '1 each', width: '18%', opacity: 0.4 },
];
---

<MainLayout
  title="Projects — Jason Paladini"
  description="Data engineering tools and analytics applications by Jason Paladini, built with Streamlit and deployed live."
  active="projects"
>
  <!-- Header -->
  <header class="border-b border-white/[0.07] grid-texture">
    <div class="max-w-content mx-auto px-8 pt-16 pb-[52px]">
      <div class="font-mono text-xs text-text-faint mb-[18px]">
        <a href="/" class="text-accent no-underline">~/</a> / projects
      </div>
      <h1 class="m-0 font-bold text-[clamp(40px,6vw,64px)] leading-[1.0] tracking-[-0.03em]">Projects</h1>
      <p class="mt-5 max-w-[560px] text-[17px] leading-[1.55] text-text-3">
        Data engineering tools and analytics applications, built with Streamlit and deployed live. Each one is open to try.
      </p>
    </div>
  </header>

  <!-- Project list -->
  <section class="max-w-content mx-auto px-8 pt-16 pb-6 flex flex-col gap-5">
    {projects.map((p) => (
      <a href={p.url} target="_blank" rel="noopener" class="no-underline text-text grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-[30px] p-[30px] border border-white/[0.09] rounded-2xl bg-panel items-center transition-colors hover:border-accent/40 hover:bg-panel-hover">
        <div class="stripe-placeholder aspect-[4/3] rounded-[10px] flex items-center justify-center font-mono text-[10px] leading-[1.4] text-text-faint text-center p-2.5">app screenshot</div>
        <div>
          <div class="flex justify-between items-baseline gap-3">
            <h2 class="m-0 font-semibold text-2xl leading-[1.1]">{p.title}</h2>
            <span class="font-mono font-medium text-xs text-accent flex-none">{p.num} ↗</span>
          </div>
          <p class="mt-2.5 mb-3.5 text-[14.5px] leading-[1.55] text-text-3 max-w-[640px]">{p.description}</p>
          <div class="flex flex-wrap gap-x-3.5 gap-y-1.5 mb-3.5 text-[13px] leading-[1.4] text-text-2">
            {p.features.map((f) => (<span>· {f}</span>))}
          </div>
          <div class="flex flex-wrap gap-1.5 font-mono text-[11px] font-medium text-text-dim">
            {p.tags.map((t) => (
              <span class="px-[9px] py-[5px] border border-white/10 rounded-[5px]">{t}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </section>

  <!-- Tech stack summary -->
  <section class="max-w-content mx-auto px-8 pt-16 pb-6">
    <h2 class="mt-0 mb-2 font-bold text-[26px] leading-[1.1] tracking-[-0.01em]">Technology stack</h2>
    <p class="mt-0 mb-7 text-[15px] leading-[1.5] text-text-3">Across these projects, by frequency.</p>
    <div class="border border-white/[0.09] rounded-2xl bg-panel p-7 flex flex-col gap-4">
      {techBars.map((bar) => (
        <div class="grid grid-cols-[110px_1fr_70px] sm:grid-cols-[160px_1fr_90px] gap-3.5 items-center">
          <span class="font-mono text-[13px] text-text-2">{bar.label}</span>
          <div class="h-3 rounded-md bg-accent" style={`width:${bar.width};opacity:${bar.opacity}`}></div>
          <span class="font-mono text-xs text-text-faint text-right">{bar.count}</span>
        </div>
      ))}
    </div>
  </section>
</MainLayout>
