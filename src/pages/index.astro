---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const projects = [
  {
    title: 'Power BI vs Snowflake',
    description: 'Performance, feature and cost comparison between Power BI semantic models and Snowflake.',
    tags: ['Streamlit', 'Snowflake'],
    url: 'https://jphzn-pbi-snwflk-compare-20260125.streamlit.app/',
  },
  {
    title: 'Model Explorer',
    description: 'Interactive view of Power BI semantic models and dbt relationships — lineage and metadata.',
    tags: ['dbt', 'Power BI'],
    url: 'https://jp-pbi-model-explorer.streamlit.app/',
  },
  {
    title: 'Data Profiling Tool',
    description: 'Automated quality assessment — distributions, null detection and type validation for new sources.',
    tags: ['Python', 'Data Quality'],
    url: 'https://jphzn-profiling.streamlit.app/',
  },
  {
    title: 'Claims Timeliness',
    description: 'Healthcare claims KPIs and trend analysis — processing times, bottlenecks, operational metrics.',
    tags: ['BI', 'Healthcare'],
    url: 'https://jp-claims-timeliness.streamlit.app/',
  },
];

const stack = [
  { title: 'Cloud Lakehouse', value: 'Microsoft Fabric · Databricks · Snowflake' },
  { title: 'Traditional Systems', value: 'SQL Server · DB2 · SSIS' },
  { title: 'Reporting', value: 'Tableau Server · Power BI' },
  { title: 'Governance', value: 'Alation · Purview · Confluence' },
  { title: 'Languages & Practices', value: 'SQL · Python · dbt · Azure DevOps · CI/CD' },
  { title: 'Automation & AI', value: 'Power Automate · Copilot Studio · MLflow' },
];

const capabilities = [
  'Own all data products in my domain — models, transforms, semantic layers and governance entries.',
  'Review and approve all analyst contributions through CI/CD pipelines and PR checks.',
  'Build production RAG systems on governed enterprise data with real access controls.',
  'Modernize ingestion and platform architecture without breaking what’s already running.',
];

const experience = [
  {
    period: '2017 — Present',
    role: 'Data Engineer',
    org: 'Horizon Blue Cross Blue Shield of New Jersey',
    blurb: 'Built the call-intelligence lakehouse and production GenAI; migrated legacy SQL Server and DB2 to Databricks, Snowflake and Fabric while keeping reporting live for a 25-person analytics team.',
  },
  {
    period: '2005 — 2010',
    role: 'Corporal',
    org: 'U.S. Marine Corps · Marine Aircraft Logistics Squadron 16',
    blurb: 'Led supply-chain operations for Marine aviation — a 25-person team, 12,000+ line items and multiple satellite inventories supporting aircraft readiness.',
  },
  {
    period: '2012 — 2016',
    role: 'Stony Brook University',
    org: 'Computational Modeling, Bioinformatics, Mathematical Biology',
    blurb: null,
  },
];

const architecture = [
  { stage: 'Bronze · raw capture', detail: 'recordings + metadata, landed as-is', accent: false },
  { stage: 'Silver · transcribe + analyze', detail: 'transcription, LLM analysis, embeddings', accent: false },
  { stage: 'Gold · serving tables', detail: 'curated, governed, query-ready', accent: false },
  { stage: 'RAG · cited answers', detail: 'dual-index retrieval + vector search', accent: true },
];

const featuredBullets = [
  'A prompt control plane powered by a database table — new LLM workflows ship via config, with versioned prompts and production promotion, no code changes.',
  'A dual-index RAG agent that combines transcript retrieval and prior LLM analysis through vector search, grounding answers with citations.',
  'An MLflow evaluation framework with deterministic schema checks, LLM-as-judge scoring and A/B comparison across prompts and models.',
];

// Two most recent posts for the "From the blog" teasers.
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const eyebrow = 'font-mono text-[13px] font-semibold uppercase tracking-eyebrow text-accent';
---

<MainLayout
  title="Jason Paladini — Data Engineer"
  description="Jason Paladini builds data platforms and the production GenAI that runs on them — Databricks, Snowflake, Fabric."
  active="home"
  footer="home"
>
  <!-- Hero -->
  <header class="relative overflow-hidden border-b border-white/[0.07] grid-texture mint-glow">
    <div class="relative max-w-content mx-auto px-8 pt-24 pb-[84px]">
      <div class="inline-flex items-center gap-2 font-mono text-xs text-accent border border-accent/30 bg-accent/[0.06] px-3 py-[7px] rounded-[30px] mb-7">
        <span class="w-[7px] h-[7px] rounded-full bg-accent shadow-[0_0_8px_#6ee7c7]"></span>
        Data Engineer · Horizon BCBSNJ · available for work
      </div>
      <h1 class="m-0 max-w-[14ch] font-bold text-[clamp(48px,7.6vw,88px)] leading-[0.96] tracking-[-0.035em]">
        Data platforms, and the AI that runs on them<span class="text-accent">.</span>
      </h1>
      <p class="mt-[30px] max-w-[620px] text-[clamp(16px,1.9vw,20px)] leading-[1.55] text-text-3">
        I'm Jason — an analytics engineer and software developer. I build data applications and BI platforms across on-prem and cloud (Databricks, Snowflake, Fabric), and the production RAG systems that run on governed enterprise data.
      </p>
      <div class="flex flex-wrap gap-3 mt-[38px]">
        <a href="#featured" class="font-semibold text-[15px] text-accent-ink bg-accent px-[22px] py-3.5 rounded-[9px] no-underline transition-colors hover:bg-accent-bright">View featured work</a>
        <a href="/projects" class="font-semibold text-[15px] text-text border border-white/[0.18] px-[22px] py-3.5 rounded-[9px] no-underline transition-colors hover:border-accent hover:text-accent">Browse projects</a>
      </div>
    </div>
  </header>

  <!-- Featured case study -->
  <section id="featured" class="max-w-content mx-auto px-8 pt-[88px] pb-6">
    <div class="flex items-baseline justify-between mb-9 flex-wrap gap-2.5">
      <h2 class={`m-0 ${eyebrow}`}>Featured / 01</h2>
      <span class="font-mono text-xs text-text-faint">Horizon Blue Cross Blue Shield of NJ</span>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10 items-start">
      <div>
        <h3 class="m-0 font-bold text-[clamp(30px,4vw,42px)] leading-[1.04] tracking-[-0.02em]">Call Intelligence Lakehouse</h3>
        <p class="mt-[18px] text-[17px] leading-[1.6] text-text-3">
          An end-to-end pipeline that ingests, transcribes, analyzes and semantically searches customer-service recordings — built on a Bronze/Silver/Gold + embeddings architecture, with a dual-index RAG agent that grounds every answer in citations.
        </p>
        <div class="mt-[26px] flex flex-col gap-3">
          {featuredBullets.map((b) => (
            <div class="flex gap-3 items-start">
              <span class="text-accent font-mono font-semibold text-[13px] leading-[1.5] flex-none">+</span>
              <span class="text-[14.5px] leading-[1.5] text-text-2">{b}</span>
            </div>
          ))}
        </div>
        <a href="/blog/call-intelligence-lakehouse" class="inline-block mt-[26px] font-mono font-semibold text-sm text-accent no-underline hover:text-accent-bright transition-colors">Read the write-up →</a>
      </div>
      <div class="border border-white/[0.09] rounded-[14px] bg-panel p-[22px]">
        <div class="font-mono text-[11px] text-text-faint uppercase tracking-[0.14em] mb-4">Architecture</div>
        <div class="flex flex-col gap-2.5">
          {architecture.map((node, i) => (
            <>
              <div class:list={[
                'p-3.5 rounded-[10px] border',
                node.accent ? 'border-accent bg-accent/[0.08]' : 'border-white/[0.08] bg-white/[0.02]',
              ]}>
                <div class:list={['font-semibold text-sm leading-tight', node.accent ? 'text-accent-soft' : 'text-text']}>{node.stage}</div>
                <div class:list={['font-mono text-[12.5px] leading-[1.4] mt-1', node.accent ? 'text-[#7fd9c2]' : 'text-text-faint']}>{node.detail}</div>
              </div>
              {i < architecture.length - 1 && (
                <div class="text-center text-arrow font-mono font-semibold text-xs">↓</div>
              )}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Selected projects -->
  <section class="max-w-content mx-auto px-8 pt-20 pb-6">
    <div class="flex items-baseline justify-between mb-[30px] flex-wrap gap-2.5">
      <h2 class={`m-0 ${eyebrow}`}>Selected projects</h2>
      <a href="/projects" class="font-mono font-semibold text-[13px] text-text-3 no-underline hover:text-accent transition-colors">View all 6 →</a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px]">
      {projects.map((p) => (
        <a href={p.url} target="_blank" rel="noopener" class="no-underline text-text p-6 border border-white/[0.09] rounded-[14px] bg-panel flex flex-col gap-2.5 transition-colors hover:border-accent/40 hover:bg-panel-hover">
          <div class="flex justify-between items-center">
            <span class="font-semibold text-[19px] leading-[1.15]">{p.title}</span>
            <span class="text-accent font-mono font-semibold text-sm">↗</span>
          </div>
          <p class="m-0 text-sm leading-[1.5] text-text-3">{p.description}</p>
          <div class="flex flex-wrap gap-1.5 mt-1 font-mono text-[11px] font-medium text-text-dim">
            {p.tags.map((t) => (
              <span class="px-2 py-[5px] border border-white/10 rounded-[5px]">{t}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Capabilities + stack -->
  <section class="max-w-content mx-auto px-8 pt-20 pb-6 grid grid-cols-1 lg:grid-cols-[0.85fr_1.15fr] gap-12">
    <div>
      <h2 class={`mt-0 mb-[22px] ${eyebrow}`}>What I do</h2>
      <div class="flex flex-col gap-3.5">
        {capabilities.map((c) => (
          <p class="m-0 text-[15px] leading-[1.55] text-text-2">{c}</p>
        ))}
      </div>
    </div>
    <div>
      <h2 class={`mt-0 mb-[22px] ${eyebrow}`}>Platforms & tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px]">
        {stack.map((s) => (
          <div>
            <div class="font-semibold text-[13px] leading-[1.3] text-text mb-1.5">{s.title}</div>
            <div class="font-mono text-[12.5px] leading-[1.5] text-text-dim">{s.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section class="max-w-content mx-auto px-8 pt-20 pb-6">
    <h2 class={`mt-0 mb-[30px] ${eyebrow}`}>Experience</h2>
    <div class="flex flex-col">
      {experience.map((e) => (
        <div class="grid grid-cols-1 sm:grid-cols-[140px_1fr] gap-6 py-[22px] border-t border-white/[0.09] last:border-b">
          <span class="font-mono text-[13px] leading-[1.4] text-text-faint">{e.period}</span>
          <div>
            <div class="font-semibold text-[19px] leading-tight">{e.role}</div>
            <div class="text-sm leading-[1.4] text-text-3 mt-[3px]">{e.org}</div>
            {e.blurb && <p class="mt-2.5 text-sm leading-[1.55] text-text-2 max-w-[680px]">{e.blurb}</p>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- From the blog -->
  {posts.length > 0 && (
    <section class="max-w-content mx-auto px-8 pt-20 pb-6">
      <div class="flex items-baseline justify-between mb-[30px] flex-wrap gap-2.5">
        <h2 class={`m-0 ${eyebrow}`}>From the blog</h2>
        <a href="/blog" class="font-mono font-semibold text-[13px] text-text-3 no-underline hover:text-accent transition-colors">All posts →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[18px]">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="no-underline text-text p-[26px] border border-white/[0.09] rounded-[14px] bg-panel flex flex-col gap-2.5 transition-colors hover:border-accent/40">
            <span class="font-mono text-[11px] text-text-faint">{post.data.category} · {post.data.readingTime}</span>
            <span class="font-semibold text-xl leading-tight">{post.data.title}</span>
            <span class="text-sm leading-[1.5] text-text-3">{post.data.description}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Contact -->
  <section class="max-w-content mx-auto px-8 pt-20 pb-[90px]">
    <div class="relative overflow-hidden border border-accent/[0.22] rounded-[18px] bg-panel mint-glow px-10 py-[54px] text-center">
      <div class="relative">
        <h2 class="m-0 font-bold text-[clamp(28px,4vw,40px)] leading-[1.05] tracking-[-0.02em]">Let's build something reliable.</h2>
        <p class="mt-4 mx-auto max-w-[480px] text-base leading-[1.55] text-text-3">Open to data engineering and analytics-platform work. The fastest way to reach me is email.</p>
        <div class="flex justify-center flex-wrap gap-3 mt-[30px]">
          <a href="mailto:jason@jpaladini.com" class="font-semibold text-[15px] text-accent-ink bg-accent px-[22px] py-3.5 rounded-[9px] no-underline transition-colors hover:bg-accent-bright">jason@jpaladini.com</a>
          <a href="https://github.com/jpaladini" target="_blank" rel="noopener" class="font-semibold text-[15px] text-text border border-white/[0.18] px-[22px] py-3.5 rounded-[9px] no-underline transition-colors hover:border-accent hover:text-accent">GitHub</a>
          <a href="https://linkedin.com/in/jason-paladini" target="_blank" rel="noopener" class="font-semibold text-[15px] text-text border border-white/[0.18] px-[22px] py-3.5 rounded-[9px] no-underline transition-colors hover:border-accent hover:text-accent">LinkedIn</a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
